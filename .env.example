# Livoia - Environment Configuration Template
# Copy this file to .env and fill in your values

# Application settings
FLUENTIA_LOG_LEVEL=INFO
FLUENTIA_DEFAULT_PROVIDER=google
FLUENTIA_DEFAULT_AGENT=interviewer

# Google Gemini provider
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# AWS Bedrock Nova Sonic provider
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-2-sonic-v1:0

# AWS credentials (used by the Bedrock SDK directly)
# Obtain these from https://aws-global.avature.net/
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_SESSION_TOKEN=your-aws-session-token-here
